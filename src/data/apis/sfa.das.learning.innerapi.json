{
  "openapi": "3.0.4",
  "info": {
    "title": "Learning Internal API",
    "version": "v1"
  },
  "paths": {
    "/{ukprn}/learnings": {
      "get": {
        "tags": [
          "Learning"
        ],
        "summary": "Get learnings",
        "description": "Gets all apprenticeships. The response from this endpoint only contains summary apprenticeship information.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "Filter by training provider using the unique provider number.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "fundingPlatform",
            "in": "query",
            "description": "Filter by the funding platform. This parameter is optional.",
            "schema": {
              "$ref": "#/components/schemas/FundingPlatform"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Apprenticeships retrieved",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Learning"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Learning"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Learning"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/{ukprn}/academicyears/{academicYear}/learnings": {
      "get": {
        "tags": [
          "Learning"
        ],
        "summary": "Get paginated learnings for a provider between specified dates.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "UkPrn filter value",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "academicYear",
            "in": "path",
            "description": "Academic year in yyyy format (e.g. 2425)",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetLearningsByAcademicYearResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{ukprn}/{collectionYear}/{collectionPeriod}": {
      "get": {
        "tags": [
          "Learning"
        ],
        "summary": "Gets all fm36 learnings data for a given provider with episode and price data",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "Ukprn",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "collectionYear",
            "in": "path",
            "description": "Collection Year",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "collectionPeriod",
            "in": "path",
            "description": "Collection Period",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/{learningKey}": {
      "put": {
        "tags": [
          "Learning"
        ],
        "summary": "Updates the details of a learner associated with a specific learning key.",
        "parameters": [
          {
            "name": "learningKey",
            "in": "path",
            "description": "The unique identifier for the learner record to update.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "description": "The updated learner details.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLearnerRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLearnerRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateLearnerRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/{ukprn}/{learningKey}": {
      "delete": {
        "tags": [
          "Learning"
        ],
        "summary": "Removes a learner associated with a specific learning key.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "UK provider reference number. Present in the route for future requirements; currently unused.",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "learningKey",
            "in": "path",
            "description": "The unique identifier for the learner record to remove.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/{ukprn}/academicyears/{academicYear}/shortCourses": {
      "get": {
        "tags": [
          "ShortCourses"
        ],
        "summary": "Get paginated short courses for a provider within an academic year.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "Ukprn",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "academicYear",
            "in": "path",
            "description": "Academic year in yyyy format (e.g. 2425)",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesByAcademicYearResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesByAcademicYearResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesByAcademicYearResponse"
                }
              }
            }
          }
        }
      }
    },
    "/{ukprn}/{collectionYear}/shortCourses": {
      "get": {
        "tags": [
          "ShortCourses"
        ],
        "summary": "Get paginated short courses for a provider within a collection year, for earnings purposes.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "Ukprn",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "collectionYear",
            "in": "path",
            "description": "Collection year in yymm format (e.g. 2425)",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "Page number",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "Number of items per page",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesForEarningsResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesForEarningsResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetShortCoursesForEarningsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/shortCourses": {
      "post": {
        "tags": [
          "ShortCourses"
        ],
        "summary": "Creates a new draft (unapproved) short course learner.",
        "requestBody": {
          "description": "The learner and short course details.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/{ukprn}/shortCourses/{learningKey}": {
      "delete": {
        "tags": [
          "ShortCourses"
        ],
        "summary": "Deletes a short course learner record.",
        "parameters": [
          {
            "name": "ukprn",
            "in": "path",
            "description": "The ukprn of the provider in context",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "learningKey",
            "in": "path",
            "description": "The key of the short course learning record to delete.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/shortCourses/{learningKey}": {
      "put": {
        "tags": [
          "ShortCourses"
        ],
        "summary": "Updates an existing short course learner record.",
        "parameters": [
          {
            "name": "learningKey",
            "in": "path",
            "description": "The key of the short course learning record to update.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "requestBody": {
          "description": "The updated learner and short course details.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreateDraftShortCourseRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateShortCourseResult"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateShortCourseResult"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/UpdateShortCourseResult"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApprenticeshipLearnerUpdateDetails": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "description": "The first or given names of the learner",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "description": "The last name of the learner",
            "nullable": true
          },
          "emailAddress": {
            "type": "string",
            "description": "The email address of the learner",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "description": "Date of birth of the learner",
            "format": "date-time"
          },
          "care": {
            "$ref": "#/components/schemas/CareDetails"
          },
          "completionDate": {
            "type": "string",
            "description": "Date the learning completes, this will be null until completion is confirmed",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Learner details to be updated for Apprenticeships"
      },
      "BreakInLearning": {
        "type": "object",
        "properties": {
          "startDate": {
            "type": "string",
            "description": "Start date of the break in learning",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "description": "End date of the break in learning",
            "format": "date-time"
          },
          "priorPeriodExpectedEndDate": {
            "type": "string",
            "description": "Expected end date of the period in learning which this break truncates",
            "format": "date-time"
          }
        },
        "additionalProperties": false,
        "description": "Break in learning details"
      },
      "CareDetails": {
        "type": "object",
        "properties": {
          "hasEHCP": {
            "type": "boolean",
            "description": "Indicates whether the learner has an Education, Health, and Care Plan (EHCP). ///"
          },
          "isCareLeaver": {
            "type": "boolean",
            "description": "Indicates whether the learner is a care leaver"
          },
          "careLeaverEmployerConsentGiven": {
            "type": "boolean",
            "description": "Indicates whether consent has been given to share information about the learner being a care leaver."
          }
        },
        "additionalProperties": false,
        "description": "Learner care details"
      },
      "Cost": {
        "type": "object",
        "properties": {
          "trainingPrice": {
            "type": "integer",
            "description": "The cost of the training, aka TNP1",
            "format": "int32"
          },
          "epaoPrice": {
            "type": "integer",
            "description": "The cost of the end-point assessment, aka TNP2",
            "format": "int32",
            "nullable": true
          },
          "fromDate": {
            "type": "string",
            "description": "The date from which this price applies",
            "format": "date-time"
          }
        },
        "additionalProperties": false,
        "description": "Cost details"
      },
      "CreateDraftShortCourseRequest": {
        "type": "object",
        "properties": {
          "learnerUpdateDetails": {
            "$ref": "#/components/schemas/ShortCourseLearnerUpdateDetails"
          },
          "learningSupport": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LearningSupportDetails"
            },
            "description": "Learning support details",
            "nullable": true
          },
          "onProgramme": {
            "$ref": "#/components/schemas/OnProgramme"
          }
        },
        "additionalProperties": false,
        "description": "Request to create a draft short course learner record"
      },
      "Delivery": {
        "type": "object",
        "properties": {
          "withdrawalDate": {
            "type": "string",
            "description": "Withdrawal during learning date",
            "format": "date-time",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Delivery Details"
      },
      "EmployerType": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "EnglishAndMaths": {
        "type": "object",
        "properties": {
          "course": {
            "type": "string",
            "description": "The standard code of the linked OnProg",
            "nullable": true
          },
          "learnAimRef": {
            "type": "string",
            "description": "The english/maths course the learner is undertaking",
            "nullable": true
          },
          "startDate": {
            "type": "string",
            "description": "Start date of the english or maths course",
            "format": "date-time"
          },
          "plannedEndDate": {
            "type": "string",
            "description": "Planned end date of the english or maths course",
            "format": "date-time"
          },
          "completionDate": {
            "type": "string",
            "description": "Date the english or maths course completes, this will be null until completion is confirmed",
            "format": "date-time",
            "nullable": true
          },
          "withdrawalDate": {
            "type": "string",
            "description": "Withdrawal date for the english or maths course, this will be null until a withdrawal is confirmed",
            "format": "date-time",
            "nullable": true
          },
          "pauseDate": {
            "type": "string",
            "description": "Pause date for this english or maths course",
            "format": "date-time",
            "nullable": true
          },
          "combinedFundingAdjustmentPercentage": {
            "type": "number",
            "description": "Combination of PriorLearningAdjustment and OtherFundingAdjustment",
            "format": "double",
            "nullable": true
          },
          "amount": {
            "type": "number",
            "description": "Amount associated with the english or maths course",
            "format": "double"
          },
          "breaksInLearning": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BreakInLearning"
            },
            "description": "Breaks in learning for the english or maths course",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "English and Maths course details"
      },
      "FundingPlatform": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "GetLearningsByAcademicYearResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "totalItems": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GetLearningsByDatesResponseItem"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GetLearningsByDatesResponseItem": {
        "type": "object",
        "properties": {
          "uln": {
            "type": "string",
            "nullable": true
          },
          "key": {
            "type": "string",
            "format": "uuid"
          }
        },
        "additionalProperties": false
      },
      "GetShortCoursesByAcademicYearResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "totalItems": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShortCourseLearnerItem"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GetShortCoursesForEarningsEpisode": {
        "type": "object",
        "properties": {
          "courseCode": {
            "type": "string",
            "nullable": true
          },
          "isApproved": {
            "type": "boolean"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "learnerRef": {
            "type": "string",
            "nullable": true
          },
          "employerType": {
            "$ref": "#/components/schemas/EmployerType"
          }
        },
        "additionalProperties": false
      },
      "GetShortCoursesForEarningsItem": {
        "type": "object",
        "properties": {
          "learningKey": {
            "type": "string",
            "format": "uuid"
          },
          "learner": {
            "$ref": "#/components/schemas/GetShortCoursesForEarningsLearner"
          },
          "episodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GetShortCoursesForEarningsEpisode"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GetShortCoursesForEarningsLearner": {
        "type": "object",
        "properties": {
          "uln": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "GetShortCoursesForEarningsResponse": {
        "type": "object",
        "properties": {
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "totalItems": {
            "type": "integer",
            "format": "int32"
          },
          "pageSize": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GetShortCoursesForEarningsItem"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Learning": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string",
            "format": "uuid"
          },
          "uln": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LearningSupportDetails": {
        "type": "object",
        "properties": {
