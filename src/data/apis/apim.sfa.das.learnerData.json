            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "epaoPrice": {
            "type": "integer",
            "format": "int32"
          },
          "trainingPrice": {
            "type": "integer",
            "format": "int32"
          },
          "agreementId": {
            "type": "string",
            "nullable": true
          },
