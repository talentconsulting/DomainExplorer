        "required": true,
        "description": "Earnings profile identifier"
      },
      {
        "field": "EpisodeKey",
        "type": "guid",
        "required": true,
        "description": "Short-course episode identifier"
      },
      {
        "field": "Version",
        "type": "guid",
        "required": true,
        "description": "Profile version after update"
      },
      {
        "field": "OnProgramTotal",
        "type": "decimal",
        "required": true,
        "description": "Total on-programme amount"
      },
      {
        "field": "CompletionPayment",
        "type": "decimal",
        "required": true,
        "description": "Completion payment amount"
      },
      {
        "field": "Instalments",
        "type": "array",
        "required": true,
        "description": "Instalment lines",
        "items": {
          "type": "object",
          "fields": [
            {
              "field": "Key",
              "type": "guid",
              "required": true,
              "description": "Instalment identifier"
            },
            {
              "field": "EpisodePriceKey",
              "type": "guid",
