[
  {
    "id": "SFA.DAS.Funding.ApprenticeshipEarnings.Types.EarningsProfileUpdatedEvent",
    "name": "EarningsProfileUpdatedEvent",
    "description": "Published when apprenticeship earnings profile content/version changes (including initial profile generation and subsequent updates such as on-programme changes, learning support, maths/english, or learner removal recalculation to zero).",
    "payload": [
      {
        "field": "EarningsProfileId",
        "type": "guid",
        "required": true,
        "description": "Earnings profile identifier"
      },
      {
        "field": "EpisodeKey",
        "type": "guid",
        "required": true,
        "description": "Apprenticeship episode identifier"
      },
      {
        "field": "Version",
        "type": "guid",
        "required": true,
        "description": "Profile version after update"
      },
      {
        "field": "OnProgramTotal",
        "type": "decimal",
        "required": true,
        "description": "Total on-programme earning amount"
      },
      {
        "field": "CompletionPayment",
        "type": "decimal",
        "required": true,
        "description": "Completion payment amount"
      },
      {
        "field": "Instalments",
        "type": "array",
        "required": true,
        "description": "Instalment lines for the profile",
        "items": {
          "type": "object",
          "fields": [
            {
              "field": "Key",
              "type": "guid",
              "required": true,
              "description": "Instalment identifier"
            },
            {
              "field": "EpisodePriceKey",
              "type": "guid",
              "required": true,
              "description": "Related episode price key"
            },
            {
              "field": "Type",
              "type": "string",
              "required": true,
              "description": "Instalment type"
            },
            {
              "field": "AcademicYear",
              "type": "short",
              "required": true,
              "description": "Academic year (YYYY format used by system)"
            },
            {
              "field": "DeliveryPeriod",
              "type": "byte",
              "required": true,
              "description": "Funding delivery period"
            },
            {
              "field": "Amount",
              "type": "decimal",
              "required": true,
              "description": "Instalment amount"
            }
          ]
        }
      },
      {
        "field": "AdditionalPayments",
        "type": "array",
        "required": true,
        "description": "Additional incentive/support payments",
        "items": {
          "type": "object",
          "fields": [
            {
              "field": "Key",
              "type": "guid",
              "required": true,
              "description": "Additional payment identifier"
            },
            {
              "field": "AdditionalPaymentType",
              "type": "string",
              "required": true,
              "description": "Payment type/category"
            },
            {
              "field": "DueDate",
              "type": "datetime",
              "required": true,
              "description": "Date payment is due"
            },
            {
              "field": "AcademicYear",
              "type": "short",
              "required": true,
              "description": "Academic year"
            },
            {
              "field": "DeliveryPeriod",
              "type": "byte",
              "required": true,
              "description": "Funding delivery period"
            },
            {
              "field": "Amount",
              "type": "decimal",
              "required": true,
              "description": "Payment amount"
            }
          ]
        }
      },
      {
        "field": "EnglishAndMaths",
        "type": "array",
        "required": true,
        "description": "English and maths earnings breakdown",
        "items": {
          "type": "object",
          "fields": [
            {
              "field": "EnglishAndMathsKey",
              "type": "guid",
              "required": true,
              "description": "Course earning identifier"
            },
            {
              "field": "StartDate",
              "type": "datetime",
              "required": true,
              "description": "Course start date"
            },
            {
              "field": "EndDate",
              "type": "datetime",
              "required": true,
              "description": "Course end date"
            },
            {
              "field": "Course",
              "type": "string",
              "required": true,
              "description": "Course descriptor"
            },
            {
              "field": "Amount",
              "type": "decimal",
              "required": true,
              "description": "Total amount for course earnings"
            },
            {
              "field": "Instalments",
              "type": "array",
              "required": true,
              "description": "Delivery period instalments for this course",
              "items": {
                "type": "object",
                "fields": [
                  {
                    "field": "AcademicYear",
                    "type": "short",
                    "required": true,
                    "description": "Academic year"
                  },
                  {
                    "field": "DeliveryPeriod",
                    "type": "byte",
                    "required": true,
                    "description": "Funding delivery period"
                  },
                  {
                    "field": "Amount",
                    "type": "decimal",
                    "required": true,
                    "description": "Instalment amount"
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "field": "InitialGeneration",
        "type": "bool",
        "required": true,
        "description": "True when this is the first generated version"
      }
    ]
  },
  {
    "id": "SFA.DAS.Funding.ApprenticeshipEarnings.Types.ShortCourseEarningsProfileUpdatedEvent",
    "name": "ShortCourseEarningsProfileUpdatedEvent",
